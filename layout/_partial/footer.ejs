<footer id="footer">
  <% if (theme.sidebar === 'bottom'){ %>
    <%- partial('_partial/sidebar') %>
  <% } %>
  <div class="outer">
    <div id="footer-description" class="inner">
    </div>
    <div id="footer-info" class="inner">
      &copy; 2016 - <%= date(new Date(), 'YYYY') %> <%= config.author || config.title %> <br/>
      <%= __('powered_by') %> <a href="http://hexo.io/" target="_blank">Hexo</a>
    </div>
  </div>
</footer>
